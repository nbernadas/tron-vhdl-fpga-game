library ieee;
use ieee.std_logic_1164.all;

entity memory_positions is
	port(
		clk50: in std_logic;
		nrst: in std_logic;
		
		mode: in std_logic;
		write_input: in std_logic_vector(2 downto 0);
		
		game_address: in std_logic_vector(10 downto 0);
		vga_address: in std_logic_vector(14 downto 0);
		
		game_read: out std_logic_vector(2 downto 0);
		vga_read: out std_logic(2 downto 0)
	);
end memory_positions;